# Overwatch credentials — copy to .env and fill. First run seeds these into the OS keychain.
# LLM provider key (Anthropic by default; required unless OVERWATCH_LLM=glm)
ANTHROPIC_API_KEY=

# Groww read-only API token (NO trade scope — see idea.md D1)
groww_api_key=
groww_api_secret=

# Optional — run the agent on GLM-5.2 via Ollama Cloud instead of Claude.
#   Set OVERWATCH_LLM=glm and fill ollama_api_key. Unset (or =claude) → Claude default.
OVERWATCH_LLM=
ollama_api_key=
# Override only if the cloud model tag / endpoint differ from the defaults below.
# Tag is the /v1 name (glm-5.2), NOT glm-5.2:cloud.
overwatch_glm_model=glm-5.2
# GLM tags registered so /model can switch among them live (default set below).
overwatch_glm_models=glm-5.2,glm-5.1,glm-5,glm-4.7
ollama_base_url=https://ollama.com/v1

# Optional — Telegram alert delivery (walk-away alerts → bot). Leave blank to disable.
#   1. Create a bot with @BotFather → it gives you the bot token.
#   2. Send your bot any message, then get your numeric chat id from @userinfobot.
#   3. Fill both below; first run seeds them into the keychain + ~/.overwatch/telegram.json.
telegram_bot_token=
telegram_chat_id=
# Min severity to push (INFO | WARNING | CRITICAL). Default WARNING (skips INFO noise).
telegram_min_severity=
